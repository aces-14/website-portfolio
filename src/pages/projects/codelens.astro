---
import BaseLayout from '../../layouts/BaseLayout.astro';

const stats = [
  { value: '1', label: 'API call for full tree', sub: 'GitHub recursive tree endpoint' },
  { value: 'k=5', label: 'chunks retrieved per query', sub: 'top-k semantic similarity' },
  { value: '4', label: 'UI redesigns', sub: 'v1 → v2 → v3 → v4' },
  { value: '3', label: 'deployment crashes', sub: 'before first clean launch' },
  { value: '1', label: 'full pipeline rewrite', sub: 'courtesy of LangChain 1.3.1' },
  { value: '2×', label: 'LangChain import hell', sub: 'SentinelPH wasn\'t enough' },
];
---

<BaseLayout
  title="CodeLens — Case Study | Reynald Ace Pilpil"
  description="How I built a RAG tool that lets you chat with any GitHub repo — the architecture decisions, the engineering tradeoffs, and the chaos that came with it."
>
  <div class="min-h-screen bg-background">

    <!-- Sticky top bar -->
