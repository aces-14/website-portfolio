          <span class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-accent/10 border border-accent/30 text-accent font-mono text-xs rounded-sm">
            <span class="w-1.5 h-1.5 rounded-full bg-accent" style="animation: pulse 2s cubic-bezier(0.4,0,0.6,1) infinite;"></span>
            LIVE
          </span>
