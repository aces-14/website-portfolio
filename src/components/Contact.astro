---
const contacts = [
  {
    label: 'Email',
    value: 'azepilpil139@gmail.com',
    href: 'mailto:azepilpil139@gmail.com',
    description: 'Best way to reach me',
    icon: 'email',
    external: false,
  },
  {
    label: 'LinkedIn',
    value: 'linkedin.com/in/reynald-ace-pilpil',
    href: 'https://www.linkedin.com/in/reynald-ace-pilpil',
    description: 'Connect professionally',
    icon: 'linkedin',
    external: true,
  },
  {
    label: 'GitHub',
    value: 'github.com/aces-14',
    href: 'https://github.com/aces-14',
    description: 'Projects and open source',
    icon: 'github',
    external: true,
  },
  {
    label: 'Hugging Face',
    value: 'huggingface.co/acepilpil',
    href: 'https://huggingface.co/acepilpil',
    description: '7 deployed live demos',
    icon: 'huggingface',
    external: true,
  },
];
---

<section id="contact" class="py-14 md:py-20 scroll-mt-16">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="animate-on-scroll">
      <p class="text-xs font-mono text-accent uppercase tracking-[0.2em] mb-2">Contact</p>
      <div class="w-10 h-px bg-accent mb-4"></div>
    </div>

    <p class="animate-on-scroll text-text-muted text-base mb-10 max-w-xl leading-relaxed">
      Open to AI/ML engineering roles, internships, and interesting collaborations.
      Based in Cavite, Philippines — open to remote.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-10">
      {contacts.map((c) => (
        <a
          href={c.href}
          {...(c.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          aria-label={c.label}
          class="contact-card animate-on-scroll group flex flex-col gap-4 p-6 bg-surface border border-border rounded-lg hover:-translate-y-1 transition-all duration-300"
        >
          <div class="text-text-muted group-hover:text-accent transition-colors duration-200">
            {c.icon === 'email' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <rect x="2" y="4" width="20" height="16" rx="2" />
                <path d="m2 7 10 7 10-7" />
              </svg>
            )}
            {c.icon === 'linkedin' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                <rect x="2" y="9" width="4" height="12"/>
                <circle cx="4" cy="4" r="2"/>
              </svg>
            )}
            {c.icon === 'github' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.341-3.369-1.341-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.607.069-.607 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.087.636-1.337-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.934.359.309.678.919.678 1.852 0 1.337-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.138 20.161 22 16.418 22 12c0-5.523-4.477-10-10-10z" />
              </svg>
            )}
            {c.icon === 'huggingface' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-3.5-9c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm7 0c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-3.5 5c2.33 0 4.31-1.46 5.11-3.5H7.89C8.69 14.54 10.67 16 12 16z"/>
              </svg>
            )}
          </div>
          <div>
            <div class="text-text-primary font-semibold text-base group-hover:text-accent transition-colors duration-200">
              {c.label}
            </div>
            <div class="text-text-muted text-xs font-mono mt-0.5 break-all">{c.value}</div>
            <div class="text-text-muted/70 text-xs mt-1.5">{c.description}</div>
          </div>
        </a>
      ))}
    </div>

    <div class="animate-on-scroll flex flex-wrap gap-x-8 gap-y-2 text-text-muted text-sm">
      <span>
        <span class="text-text-muted/50 text-xs uppercase tracking-wider mr-2">Phone</span>
        <span class="font-mono">0968 619 1930</span>
      </span>
      <span>
        <span class="text-text-muted/50 text-xs uppercase tracking-wider mr-2">Location</span>
        <span>Cavite, Philippines</span>
      </span>
    </div>

  </div>
</section>

<style>
  .contact-card:hover {
    box-shadow: 0 0 0 1px rgba(0, 217, 255, 0.28), 0 8px 24px rgba(0, 217, 255, 0.08);
  }
</style>
