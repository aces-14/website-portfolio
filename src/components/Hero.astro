---
const stats = [
  '10 deployed projects',
  '4 agentic systems',
  'End-to-end RAG',
  'Document AI',
];
---

<section class="relative min-h-screen flex items-center overflow-hidden pt-16">
  <!-- Animated grid background -->
  <div class="absolute inset-0" aria-hidden="true">
    <div class="grid-layer absolute inset-0"></div>
    <div class="glow-1 absolute pointer-events-none"></div>
    <div class="glow-2 absolute pointer-events-none"></div>
  </div>

  <div class="relative z-10 max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
    <div class="max-w-3xl">

      <h1 class="hero-el text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight text-text-primary leading-[1.1] mb-5">
        Reynald Ace Pilpil
      </h1>

      <p class="hero-el hero-delay-1 text-lg sm:text-xl md:text-2xl font-medium text-accent mb-6 tracking-tight">
        AI / ML Engineer · Agentic LLM Systems &amp; Document AI
      </p>

      <p class="hero-el hero-delay-2 text-text-muted text-base sm:text-lg leading-relaxed max-w-2xl mb-10">
        I build production-ready ML systems — from RAG assistants and agentic LLM workflows to
        multimodal document AI. Every project ships to Hugging Face Spaces with a live demo you
        can click.
      </p>

      <div class="hero-el hero-delay-3 flex flex-wrap gap-3 mb-12">
        <a
          href="#projects"
          class="px-6 py-3 bg-accent text-background font-semibold text-sm rounded-md hover:bg-accent/90 transition-all duration-200 hover:shadow-glow-sm"
        >
          View Projects
        </a>
        <a
          href="/resume.pdf"
          download
          class="px-6 py-3 border border-border text-text-primary font-semibold text-sm rounded-md hover:border-accent hover:text-accent transition-all duration-200"
        >
          Download Resume
        </a>
        <a
          href="#contact"
          class="px-6 py-3 border border-border text-text-muted font-semibold text-sm rounded-md hover:border-accent/50 hover:text-text-primary transition-all duration-200"
        >
          Get In Touch
        </a>
      </div>

      <div class="hero-el hero-delay-4 flex flex-wrap gap-x-7 gap-y-3">
        {stats.map((stat) => (
          <span class="font-mono text-xs text-text-muted uppercase tracking-wider flex items-center gap-2">
            <span class="w-1.5 h-1.5 rounded-full bg-accent shrink-0" aria-hidden="true"></span>
            {stat}
          </span>
        ))}
      </div>

    </div>
  </div>

  <a
    href="#about"
    class="absolute bottom-8 left-1/2 -translate-x-1/2 text-text-muted hover:text-accent transition-colors animate-bounce"
    aria-label="Scroll to About section"
  >
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path d="M12 5v14M5 12l7 7 7-7" />
    </svg>
  </a>
</section>

<style>
  .grid-layer {
    background-image:
      linear-gradient(rgba(30, 30, 46, 0.45) 1px, transparent 1px),
      linear-gradient(90deg, rgba(30, 30, 46, 0.45) 1px, transparent 1px);
    background-size: 44px 44px;
    animation: gridPan 22s linear infinite;
  }

  @keyframes gridPan {
    0%   { background-position: 0 0; }
    100% { background-position: 44px 44px; }
  }

  .glow-1 {
    top: -5%;
    left: -5%;
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, rgba(0, 217, 255, 0.065) 0%, transparent 65%);
  }

  .glow-2 {
    bottom: -10%;
    right: -5%;
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(139, 92, 246, 0.055) 0%, transparent 65%);
  }

  .hero-el {
    opacity: 0;
    transform: translateY(18px);
    animation: heroUp 0.75s ease-out forwards;
  }

  .hero-delay-1 { animation-delay: 0.1s; }
  .hero-delay-2 { animation-delay: 0.2s; }
  .hero-delay-3 { animation-delay: 0.32s; }
  .hero-delay-4 { animation-delay: 0.45s; }

  @keyframes heroUp {
    to { opacity: 1; transform: translateY(0); }
  }
</style>
