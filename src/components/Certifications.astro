---
const certs = [
  {
    name: 'Google Data Analytics Professional',
    issuer: 'Google · Coursera',
    date: '2024',
    verifyUrl: 'https://coursera.org/share/4e5721b543e2a210148f07cf75bbedff',
    icon: 'google',
  },
  {
    name: 'Foundation: Introduction to LangGraph',
    issuer: 'LangChain Academy',
    date: '2026',
    verifyUrl: 'https://academy.langchain.com/certificates/xutvs8u89w',
    icon: 'langchain',
  },
];
---

<section id="certifications" class="py-14 md:py-20 scroll-mt-16">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="animate-on-scroll">
      <p class="text-xs font-mono text-accent uppercase tracking-[0.2em] mb-2">Certifications</p>
      <div class="w-10 h-px bg-accent mb-12"></div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 max-w-3xl">
      {certs.map((cert) => (
        <div class="cert-card animate-on-scroll flex flex-col gap-5 p-6 bg-surface border border-border rounded-lg">

          <!-- Icon + meta -->
          <div class="flex items-start gap-4">
            <div class="shrink-0 w-10 h-10 rounded-md bg-background border border-border flex items-center justify-center">
              {cert.icon === 'google' && (
                <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                  <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                  <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                  <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                </svg>
              )}
              {cert.icon === 'langchain' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                  <path d="M8 12a4 4 0 0 1 4-4h1a3 3 0 0 1 0 6h-1" stroke="#00D9FF" stroke-width="1.8" stroke-linecap="round"/>
                  <path d="M16 12a4 4 0 0 1-4 4h-1a3 3 0 0 1 0-6h1" stroke="#00D9FF" stroke-width="1.8" stroke-linecap="round"/>
                </svg>
              )}
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-text-primary font-semibold text-sm leading-snug mb-1">
                {cert.name}
              </h3>
              <p class="text-text-muted text-xs font-mono">{cert.issuer}</p>
              <p class="text-text-muted/60 text-xs font-mono mt-0.5">{cert.date}</p>
            </div>
          </div>

          <!-- Verify button -->
          <a
            href={cert.verifyUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="verify-btn inline-flex items-center gap-2 px-4 py-2 border border-border rounded-md text-text-muted text-xs font-mono hover:border-accent/50 hover:text-accent transition-all duration-200 self-start"
          >
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            Verify Certificate
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M7 17L17 7M17 7H7M17 7v10"/>
            </svg>
          </a>

        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .cert-card {
    transition: border-color 0.3s, box-shadow 0.3s;
  }
  .cert-card:hover {
    border-color: rgba(0, 217, 255, 0.25);
    box-shadow: 0 4px 20px rgba(0, 217, 255, 0.06);
  }
</style>
