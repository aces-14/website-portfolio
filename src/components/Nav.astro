---
const links = [
  { href: '#about', label: 'About' },
  { href: '#skills', label: 'Skills' },
  { href: '#projects', label: 'Projects' },
  { href: '#experience', label: 'Experience' },
  { href: '#contact', label: 'Contact' },
];
---

<nav id="site-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <a href="/" class="font-mono text-sm font-medium text-accent tracking-widest">
        RAP<span class="text-text-muted">._</span>
      </a>

      <ul class="hidden md:flex items-center gap-8" role="list">
        {links.map((link) => (
          <li>
            <a
              href={link.href}
              class="nav-link text-xs text-text-muted hover:text-text-primary transition-colors duration-200 uppercase tracking-[0.15em]"
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <button
        id="nav-toggle"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="nav-menu"
        class="md:hidden p-2 -mr-2 text-text-muted hover:text-text-primary transition-colors"
      >
        <svg id="icon-open" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
        <svg id="icon-close" class="hidden" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>
  </div>

  <div
    id="nav-menu"
    class="md:hidden hidden border-t border-border"
    role="navigation"
    aria-label="Mobile navigation"
  >
    <ul class="max-w-6xl mx-auto px-4 py-5 flex flex-col gap-5" role="list">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class="nav-link mobile-link text-sm text-text-muted hover:text-accent transition-colors duration-200 uppercase tracking-[0.15em]"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  #site-nav.scrolled {
    background: rgba(10, 10, 15, 0.92);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(30, 30, 46, 0.9);
  }

  #nav-menu {
    background: rgba(10, 10, 15, 0.98);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  .nav-link.active {
    color: #00D9FF;
  }
</style>

<script>
  const nav = document.getElementById('site-nav')!;
  const toggle = document.getElementById('nav-toggle')!;
  const menu = document.getElementById('nav-menu')!;
  const iconOpen = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 20);
  }, { passive: true });

  toggle.addEventListener('click', () => {
    const isOpen = !menu.classList.contains('hidden');
    menu.classList.toggle('hidden', isOpen);
    iconOpen.classList.toggle('hidden', !isOpen);
    iconClose.classList.toggle('hidden', isOpen);
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  document.querySelectorAll('.mobile-link').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconOpen.classList.remove('hidden');
      iconClose.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
    });
  });

  const sections = document.querySelectorAll<HTMLElement>('section[id]');
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('.nav-link');

  const sectionObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navLinks.forEach((a) => a.classList.remove('active'));
          document
            .querySelectorAll<HTMLAnchorElement>(`.nav-link[href="#${entry.target.id}"]`)
            .forEach((a) => a.classList.add('active'));
        }
      });
    },
    { rootMargin: '-40% 0px -55% 0px' }
  );

  sections.forEach((s) => sectionObserver.observe(s));
</script>
