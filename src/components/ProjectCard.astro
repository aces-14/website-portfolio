---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;

const categoryLabel: Record<string, string> = {
  agentic: 'Agentic',
  rag: 'RAG',
  'document-ai': 'Document AI',
  'classical-ml': 'Classical ML',
};

const formattedDesc = project.highlight
  ? project.description.replace(
      project.highlight,
      `<strong class="text-text-primary font-semibold">${project.highlight}</strong>`
    )
  : project.description;

const illustrations: Record<string, string> = {
  agentic: `
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 280 78" fill="none" preserveAspectRatio="xMidYMid meet" style="width:100%;height:100%">
      <!-- Radial glow behind orchestrator -->
      <radialGradient id="ag-glow" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#00D9FF" stop-opacity="0.12"/>
        <stop offset="100%" stop-color="#00D9FF" stop-opacity="0"/>
      </radialGradient>
      <circle cx="140" cy="38" r="30" fill="url(#ag-glow)"/>

      <!-- Input node -->
      <circle cx="18" cy="38" r="10" stroke="#00D9FF" stroke-width="1.5" opacity="0.5"/>
      <circle cx="18" cy="38" r="3" fill="#00D9FF" opacity="0.65"/>

      <!-- Branching lines from input -->
      <line x1="28" y1="32" x2="60" y2="18" stroke="#00D9FF" stroke-width="0.8" stroke-dasharray="3 2" opacity="0.35"/>
      <line x1="28" y1="38" x2="60" y2="38" stroke="#00D9FF" stroke-width="0.8" stroke-dasharray="3 2" opacity="0.38"/>
      <line x1="28" y1="44" x2="60" y2="58" stroke="#00D9FF" stroke-width="0.8" stroke-dasharray="3 2" opacity="0.32"/>

      <!-- Tool nodes -->
      <circle cx="68" cy="18" r="7" stroke="#00D9FF" stroke-width="1" opacity="0.42"/>
      <circle cx="68" cy="38" r="7" stroke="#00D9FF" stroke-width="1" opacity="0.45"/>
      <circle cx="68" cy="58" r="7" stroke="#00D9FF" stroke-width="1" opacity="0.38"/>

      <!-- Lines to orchestrator -->
      <line x1="75" y1="20" x2="126" y2="33" stroke="#00D9FF" stroke-width="0.8" stroke-dasharray="3 2" opacity="0.32"/>
      <line x1="75" y1="38" x2="126" y2="38" stroke="#00D9FF" stroke-width="0.8" stroke-dasharray="3 2" opacity="0.38"/>
      <line x1="75" y1="56" x2="126" y2="43" stroke="#00D9FF" stroke-width="0.8" stroke-dasharray="3 2" opacity="0.30"/>

      <!-- Central orchestrator -->
      <circle cx="140" cy="38" r="14" stroke="#00D9FF" stroke-width="1.5" opacity="0.72"/>
      <circle cx="140" cy="38" r="5" fill="#00D9FF" opacity="0.82"/>

      <!-- Lines from orchestrator to output tools -->
      <line x1="154" y1="33" x2="196" y2="20" stroke="#00D9FF" stroke-width="0.8" stroke-dasharray="3 2" opacity="0.32"/>
      <line x1="154" y1="38" x2="196" y2="38" stroke="#00D9FF" stroke-width="0.8" stroke-dasharray="3 2" opacity="0.38"/>
      <line x1="154" y1="43" x2="196" y2="56" stroke="#00D9FF" stroke-width="0.8" stroke-dasharray="3 2" opacity="0.28"/>

      <!-- Output tool nodes -->
      <circle cx="204" cy="20" r="7" stroke="#00D9FF" stroke-width="1" opacity="0.38"/>
      <circle cx="204" cy="38" r="7" stroke="#00D9FF" stroke-width="1" opacity="0.42"/>
      <circle cx="204" cy="56" r="7" stroke="#00D9FF" stroke-width="1" opacity="0.35"/>

      <!-- Lines to output -->
      <line x1="211" y1="22" x2="250" y2="33" stroke="#00D9FF" stroke-width="0.8" stroke-dasharray="3 2" opacity="0.30"/>
      <line x1="211" y1="38" x2="250" y2="38" stroke="#00D9FF" stroke-width="0.8" stroke-dasharray="3 2" opacity="0.35"/>
      <line x1="211" y1="54" x2="250" y2="43" stroke="#00D9FF" stroke-width="0.8" stroke-dasharray="3 2" opacity="0.28"/>

      <!-- Output node -->
      <circle cx="260" cy="38" r="10" stroke="#00D9FF" stroke-width="1.5" opacity="0.52"/>
      <circle cx="260" cy="38" r="3" fill="#00D9FF" opacity="0.6"/>

      <!-- Labels -->
      <text x="10" y="66" font-family="monospace" font-size="6" fill="#00D9FF" opacity="0.5">INPUT</text>
      <text x="122" y="66" font-family="monospace" font-size="6" fill="#00D9FF" opacity="0.55">ORCHESTRATOR</text>
      <text x="250" y="66" font-family="monospace" font-size="6" fill="#00D9FF" opacity="0.45">OUT</text>
    </svg>`,

  rag: `
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 280 78" fill="none" preserveAspectRatio="xMidYMid meet" style="width:100%;height:100%">
      <!-- Document (corpus) -->
      <rect x="8" y="10" width="44" height="52" rx="3" stroke="#00D9FF" stroke-width="1.5" opacity="0.52"/>
      <line x1="15" y1="21" x2="45" y2="21" stroke="#00D9FF" stroke-width="0.8" opacity="0.38"/>
      <line x1="15" y1="29" x2="45" y2="29" stroke="#00D9FF" stroke-width="0.8" opacity="0.38"/>
      <line x1="15" y1="37" x2="45" y2="37" stroke="#00D9FF" stroke-width="0.8" opacity="0.35"/>
      <line x1="15" y1="45" x2="40" y2="45" stroke="#00D9FF" stroke-width="0.8" opacity="0.28"/>
      <line x1="15" y1="53" x2="36" y2="53" stroke="#00D9FF" stroke-width="0.8" opacity="0.22"/>

      <!-- Arrow 1 -->
      <line x1="55" y1="36" x2="74" y2="36" stroke="#00D9FF" stroke-width="1" opacity="0.48"/>
      <polyline points="70,32 74,36 70,40" stroke="#00D9FF" stroke-width="1" opacity="0.48"/>

      <!-- Chunked pieces -->
      <rect x="78" y="14" width="18" height="14" rx="2" stroke="#00D9FF" stroke-width="1" opacity="0.42"/>
      <rect x="78" y="32" width="18" height="14" rx="2" stroke="#00D9FF" stroke-width="1" opacity="0.45"/>
      <rect x="78" y="50" width="18" height="14" rx="2" stroke="#00D9FF" stroke-width="1" opacity="0.38"/>

      <!-- Arrow 2 -->
      <line x1="100" y1="36" x2="118" y2="36" stroke="#00D9FF" stroke-width="1" opacity="0.48"/>
      <polyline points="114,32 118,36 114,40" stroke="#00D9FF" stroke-width="1" opacity="0.48"/>

      <!-- Vector dots cluster -->
      <radialGradient id="rag-glow" cx="50%" cy="50%" r="50%">
        <stop offset="0%" stop-color="#00D9FF" stop-opacity="0.1"/>
        <stop offset="100%" stop-color="#00D9FF" stop-opacity="0"/>
      </radialGradient>
      <circle cx="140" cy="36" r="22" fill="url(#rag-glow)"/>
      <circle cx="130" cy="26" r="3.5" fill="#00D9FF" opacity="0.52"/>
      <circle cx="143" cy="20" r="2.5" fill="#00D9FF" opacity="0.38"/>
      <circle cx="150" cy="32" r="3.5" fill="#00D9FF" opacity="0.55"/>
      <circle cx="128" cy="40" r="2.5" fill="#00D9FF" opacity="0.42"/>
      <circle cx="140" cy="48" r="3" fill="#00D9FF" opacity="0.48"/>
      <circle cx="152" cy="46" r="2" fill="#00D9FF" opacity="0.35"/>
      <circle cx="135" cy="36" r="2" fill="#00D9FF" opacity="0.45"/>
      <!-- Retrieval highlight -->
      <circle cx="150" cy="32" r="8" stroke="#00D9FF" stroke-width="0.8" stroke-dasharray="3 2" opacity="0.35"/>

      <!-- Arrow 3 -->
      <line x1="164" y1="36" x2="182" y2="36" stroke="#00D9FF" stroke-width="1" opacity="0.48"/>
      <polyline points="178,32 182,36 178,40" stroke="#00D9FF" stroke-width="1" opacity="0.48"/>

      <!-- Answer box -->
      <rect x="186" y="10" width="86" height="52" rx="3" stroke="#00D9FF" stroke-width="1.5" opacity="0.5"/>
      <line x1="193" y1="23" x2="265" y2="23" stroke="#00D9FF" stroke-width="0.8" opacity="0.4"/>
      <line x1="193" y1="32" x2="262" y2="32" stroke="#00D9FF" stroke-width="0.8" opacity="0.35"/>
      <line x1="193" y1="41" x2="258" y2="41" stroke="#00D9FF" stroke-width="0.8" opacity="0.30"/>
      <line x1="193" y1="50" x2="248" y2="50" stroke="#00D9FF" stroke-width="0.8" opacity="0.22"/>

      <!-- Labels -->
      <text x="14" y="71" font-family="monospace" font-size="6" fill="#00D9FF" opacity="0.45">CORPUS</text>
      <text x="80" y="71" font-family="monospace" font-size="6" fill="#00D9FF" opacity="0.42">CHUNKS</text>
      <text x="126" y="71" font-family="monospace" font-size="6" fill="#00D9FF" opacity="0.48">VECTORS</text>
      <text x="196" y="71" font-family="monospace" font-size="6" fill="#00D9FF" opacity="0.45">ANSWER + CITATIONS</text>
    </svg>`,

  'document-ai': `
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 280 78" fill="none" preserveAspectRatio="xMidYMid meet" style="width:100%;height:100%">
      <!-- Scan-frame corners -->
      <path d="M18 26 L18 12 L32 12" stroke="#00D9FF" stroke-width="1.5" opacity="0.52"/>
      <path d="M110 26 L110 12 L96 12" stroke="#00D9FF" stroke-width="1.5" opacity="0.52"/>
      <path d="M18 52 L18 66 L32 66" stroke="#00D9FF" stroke-width="1.5" opacity="0.52"/>
      <path d="M110 52 L110 66 L96 66" stroke="#00D9FF" stroke-width="1.5" opacity="0.52"/>

      <!-- Document body -->
      <rect x="28" y="14" width="70" height="50" rx="2" stroke="#00D9FF" stroke-width="1" fill="none" opacity="0.3"/>

      <!-- Text lines in document -->
      <line x1="35" y1="24" x2="91" y2="24" stroke="#00D9FF" stroke-width="0.8" opacity="0.35"/>
      <line x1="35" y1="32" x2="88" y2="32" stroke="#00D9FF" stroke-width="0.8" opacity="0.35"/>
      <line x1="35" y1="40" x2="85" y2="40" stroke="#00D9FF" stroke-width="0.8" opacity="0.35"/>
      <line x1="35" y1="48" x2="78" y2="48" stroke="#00D9FF" stroke-width="0.8" opacity="0.28"/>
      <line x1="35" y1="56" x2="70" y2="56" stroke="#00D9FF" stroke-width="0.8" opacity="0.22"/>

      <!-- Active scan line + highlight above it -->
      <rect x="26" y="14" width="74" height="24" fill="#00D9FF" fill-opacity="0.04"/>
      <line x1="26" y1="38" x2="112" y2="38" stroke="#00D9FF" stroke-width="1.8" opacity="0.78"/>

      <!-- Arrow -->
      <line x1="120" y1="38" x2="145" y2="38" stroke="#00D9FF" stroke-width="1" opacity="0.52"/>
      <polyline points="141,34 145,38 141,42" stroke="#00D9FF" stroke-width="1" opacity="0.52"/>

      <!-- Structured output box -->
      <rect x="150" y="8" width="122" height="60" rx="3" stroke="#00D9FF" stroke-width="1.5" opacity="0.52"/>
      <line x1="150" y1="22" x2="272" y2="22" stroke="#00D9FF" stroke-width="0.6" opacity="0.25"/>
      <line x1="200" y1="8" x2="200" y2="68" stroke="#00D9FF" stroke-width="0.6" opacity="0.2"/>

      <!-- Key-value rows -->
      <text x="155" y="19" font-family="monospace" font-size="5.8" fill="#00D9FF" opacity="0.42">key</text>
      <text x="206" y="19" font-family="monospace" font-size="5.8" fill="#00D9FF" opacity="0.42">value</text>

      <text x="155" y="32" font-family="monospace" font-size="6.5" fill="#00D9FF" opacity="0.58">merchant</text>
      <text x="206" y="32" font-family="monospace" font-size="6.5" fill="#00D9FF" opacity="0.48">"Starbucks"</text>

      <text x="155" y="44" font-family="monospace" font-size="6.5" fill="#00D9FF" opacity="0.55">total</text>
      <text x="206" y="44" font-family="monospace" font-size="6.5" fill="#00D9FF" opacity="0.48">₱342.00</text>

      <text x="155" y="56" font-family="monospace" font-size="6.5" fill="#00D9FF" opacity="0.5">items</text>
      <text x="206" y="56" font-family="monospace" font-size="6.5" fill="#00D9FF" opacity="0.42">[3 found]</text>

      <text x="155" y="66" font-family="monospace" font-size="6" fill="#00D9FF" opacity="0.4">confidence</text>
      <text x="206" y="66" font-family="monospace" font-size="6" fill="#00D9FF" opacity="0.38">93.96%</text>
    </svg>`,

  'classical-ml': `
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 280 78" fill="none" preserveAspectRatio="xMidYMid meet" style="width:100%;height:100%">
      <!-- LEFT: Bar chart -->
      <!-- Axes -->
      <line x1="18" y1="8" x2="18" y2="62" stroke="#00D9FF" stroke-width="0.9" opacity="0.4"/>
      <line x1="18" y1="62" x2="128" y2="62" stroke="#00D9FF" stroke-width="0.9" opacity="0.4"/>

      <!-- Bars -->
      <rect x="25" y="44" width="13" height="18" rx="1" fill="#00D9FF" fill-opacity="0.18" stroke="#00D9FF" stroke-width="0.8" opacity="0.48"/>
      <rect x="44" y="30" width="13" height="32" rx="1" fill="#00D9FF" fill-opacity="0.22" stroke="#00D9FF" stroke-width="0.8" opacity="0.5"/>
      <rect x="63" y="36" width="13" height="26" rx="1" fill="#00D9FF" fill-opacity="0.18" stroke="#00D9FF" stroke-width="0.8" opacity="0.45"/>
      <rect x="82" y="18" width="13" height="44" rx="1" fill="#00D9FF" fill-opacity="0.28" stroke="#00D9FF" stroke-width="0.8" opacity="0.55"/>
      <rect x="101" y="25" width="13" height="37" rx="1" fill="#00D9FF" fill-opacity="0.2" stroke="#00D9FF" stroke-width="0.8" opacity="0.48"/>

      <!-- SHAP label -->
      <text x="20" y="72" font-family="monospace" font-size="6" fill="#00D9FF" opacity="0.48">SHAP IMPORTANCE</text>

      <!-- Divider -->
      <line x1="136" y1="6" x2="136" y2="68" stroke="#00D9FF" stroke-width="0.5" stroke-dasharray="3 3" opacity="0.22"/>

      <!-- RIGHT: Scatter + trend -->
      <!-- Axes -->
      <line x1="146" y1="8" x2="146" y2="62" stroke="#00D9FF" stroke-width="0.9" opacity="0.4"/>
      <line x1="146" y1="62" x2="272" y2="62" stroke="#00D9FF" stroke-width="0.9" opacity="0.4"/>

      <!-- Scatter points (low risk) -->
      <circle cx="155" cy="55" r="2.5" fill="#00D9FF" opacity="0.42"/>
      <circle cx="163" cy="50" r="2" fill="#00D9FF" opacity="0.35"/>
      <circle cx="172" cy="52" r="2.5" fill="#00D9FF" opacity="0.4"/>
      <circle cx="158" cy="44" r="2" fill="#00D9FF" opacity="0.38"/>
      <circle cx="168" cy="46" r="2.5" fill="#00D9FF" opacity="0.42"/>

      <!-- Scatter points (high risk) -->
      <circle cx="220" cy="20" r="3" fill="#00D9FF" opacity="0.62"/>
      <circle cx="232" cy="14" r="3" fill="#00D9FF" opacity="0.68"/>
      <circle cx="245" cy="18" r="2.5" fill="#00D9FF" opacity="0.58"/>
      <circle cx="255" cy="12" r="3" fill="#00D9FF" opacity="0.65"/>
      <circle cx="226" cy="26" r="2.5" fill="#00D9FF" opacity="0.55"/>
      <circle cx="240" cy="22" r="2" fill="#00D9FF" opacity="0.5"/>

      <!-- Mid-range -->
      <circle cx="193" cy="38" r="2.5" fill="#00D9FF" opacity="0.48"/>
      <circle cx="205" cy="34" r="2.5" fill="#00D9FF" opacity="0.52"/>
      <circle cx="215" cy="30" r="2" fill="#00D9FF" opacity="0.45"/>

      <!-- Decision boundary -->
      <path d="M150 58 Q200 42 265 15" stroke="#00D9FF" stroke-width="1.4" stroke-dasharray="5 2" opacity="0.48"/>

      <text x="148" y="72" font-family="monospace" font-size="6" fill="#00D9FF" opacity="0.45">CHURN PROBABILITY</text>
    </svg>`,
};

const illustration = illustrations[project.category] ?? '';
---

<article
  data-category={project.category}
  data-modal-target={`modal-${project.slug}`}
  class="project-card group relative bg-surface border border-border rounded-lg overflow-hidden transition-all duration-300 hover:-translate-y-1 flex flex-col cursor-pointer"
  role="button"
  tabindex="0"
  aria-haspopup="dialog"
  aria-label={`View details for ${project.title}`}
>
  <!-- Thumbnail -->
  <div class="relative h-36 overflow-hidden shrink-0">
    <div class="thumb-bg absolute inset-0"></div>
    <div class="absolute inset-0" set:html={illustration} />
    <div class="absolute bottom-2.5 left-3 z-10">
      <span class="px-2 py-0.5 bg-background/85 border border-border text-accent text-xs font-mono rounded-sm">
        {categoryLabel[project.category]}
      </span>
    </div>
  </div>

  <!-- Body -->
  <div class="p-5 flex flex-col flex-1">
    <h3 class="text-text-primary font-semibold text-[0.95rem] leading-snug mb-1 group-hover:text-accent transition-colors duration-200">
      {project.title}
    </h3>
    <p class="text-text-muted text-[0.7rem] font-mono uppercase tracking-wider mb-3">
      {project.subtitle}
    </p>
    <p class="text-text-muted text-sm leading-relaxed mb-4 flex-1 line-clamp-4" set:html={formattedDesc} />

    <!-- Tech pills -->
    <div class="flex flex-wrap gap-1.5 mb-4">
      {project.tech.map((t) => (
        <span class="px-2 py-0.5 bg-background border border-border text-text-muted text-[0.65rem] font-mono rounded-sm">
          {t}
        </span>
      ))}
    </div>

    <!-- Link buttons -->
    <div class="flex items-center gap-2 mt-auto pt-1">
      {project.links.huggingface && (
        <a
          href={project.links.huggingface}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${project.title} on Hugging Face`}
          title="Live Demo on Hugging Face"
          class="icon-btn"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-3.5-9c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm7 0c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-3.5 5c2.33 0 4.31-1.46 5.11-3.5H7.89C8.69 14.54 10.67 16 12 16z"/>
          </svg>
          <span class="text-[0.65rem] font-mono">Space</span>
        </a>
      )}
      {project.links.github && (
        <a
          href={project.links.github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${project.title} GitHub repository`}
          title="GitHub Repository"
          class="icon-btn"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.341-3.369-1.341-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.607.069-.607 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.087.636-1.337-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.934.359.309.678.919.678 1.852 0 1.337-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.138 20.161 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
          </svg>
          <span class="text-[0.65rem] font-mono">GitHub</span>
        </a>
      )}
      {project.links.colab && (
        <a
          href={project.links.colab}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${project.title} Google Colab notebook`}
          title="Google Colab Notebook"
          class="icon-btn"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M4.54 9.46 2.19 7.1a6.93 6.93 0 0 0 0 9.79l2.35-2.35a3.59 3.59 0 0 1 0-5.08z" opacity=".8"/>
            <path d="m19.46 9.46-2.35 2.35a3.59 3.59 0 0 1 0 5.08l2.35 2.35a6.93 6.93 0 0 0 0-9.79z" opacity=".6"/>
            <path d="M14.54 7.1A6.86 6.86 0 0 0 12 6.5a6.86 6.86 0 0 0-2.54.5L7.1 4.65A10.33 10.33 0 0 1 12 3.5c1.77 0 3.43.44 4.9 1.15z" opacity=".4"/>
            <path d="m16.9 19.35-2.36-2.35a3.55 3.55 0 0 1-5.08 0L7.1 19.35A6.93 6.93 0 0 0 12 21a6.93 6.93 0 0 0 4.9-1.65z"/>
          </svg>
          <span class="text-[0.65rem] font-mono">Colab</span>
        </a>
      )}
      {project.links.apiDocs && (
        <a
          href={project.links.apiDocs}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${project.title} API documentation`}
          title="API Documentation"
          class="icon-btn"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14,2 14,8 20,8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
          </svg>
          <span class="text-[0.65rem] font-mono">API Docs</span>
        </a>
      )}
    </div>
  </div>
</article>

