---
import { projects } from '../data/projects';
import ProjectCard from './ProjectCard.astro';

const filters = [
  { id: 'all', label: 'All' },
  { id: 'agentic', label: 'Agentic' },
  { id: 'rag', label: 'RAG' },
  { id: 'document-ai', label: 'Document AI' },
  { id: 'classical-ml', label: 'Classical ML' },
];

const categoryLabel: Record<string, string> = {
  agentic: 'Agentic',
  rag: 'RAG',
  'document-ai': 'Document AI',
  'classical-ml': 'Classical ML',
};
---

<section id="projects" class="py-14 md:py-20 scroll-mt-16">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">

    <div class="animate-on-scroll">
      <p class="text-xs font-mono text-accent uppercase tracking-[0.2em] mb-2">Projects</p>
      <div class="w-10 h-px bg-accent mb-8"></div>
    </div>

    <!-- Filter tabs -->
    <div
      class="animate-on-scroll flex flex-wrap gap-2 mb-8"
      role="group"
      aria-label="Filter projects by category"
    >
      {filters.map((f, i) => (
        <button
          data-filter={f.id}
          class:list={[
            'filter-btn px-4 py-1.5 text-xs font-mono rounded-sm border transition-all duration-200',
            i === 0
              ? 'border-accent text-accent active-filter'
              : 'border-border text-text-muted hover:border-accent/40 hover:text-text-primary',
          ]}
          aria-pressed={i === 0}
        >
          {f.label}
        </button>
      ))}
    </div>

    <!-- Grid -->
    <div id="projects-grid" class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {projects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>

  </div>
</section>

<!-- Modals — pre-rendered at build time, one per project (blog projects use a full page instead) -->
{projects.filter((p) => !p.blogUrl).map((project) => {
  const desc = project.highlight
    ? project.description.replace(
        project.highlight,
        `<strong class="text-text-primary font-medium">${project.highlight}</strong>`
      )
    : project.description;

  return (
    <dialog id={`modal-${project.slug}`} class="project-modal" aria-modal="true">
      <div class="modal-inner">

        <!-- Header -->
        <div class="flex items-start justify-between gap-4 mb-5">
          <div class="flex-1 min-w-0">
            <span class="inline-block px-2 py-0.5 mb-3 bg-background border border-border text-accent text-xs font-mono rounded-sm">
              {categoryLabel[project.category]}
            </span>
            <h2 class="text-text-primary font-bold text-xl leading-snug">{project.title}</h2>
            <p class="text-text-muted text-xs font-mono uppercase tracking-wider mt-1">{project.subtitle}</p>
          </div>
          <button
            class="modal-close shrink-0 p-1.5 text-text-muted hover:text-text-primary transition-colors rounded-md hover:bg-surface mt-0.5"
            aria-label="Close project details"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <line x1="18" y1="6" x2="6" y2="18"/>
              <line x1="6" y1="6" x2="18" y2="18"/>
            </svg>
          </button>
        </div>

        <!-- Description -->
        <p class="text-text-muted text-sm leading-relaxed mb-6" set:html={desc} />

        <!-- Tech stack -->
        <div class="mb-6">
          <p class="text-xs font-mono text-text-muted uppercase tracking-wider mb-3">Stack</p>
          <div class="flex flex-wrap gap-2">
            {project.tech.map((t) => (
              <span class="px-2.5 py-1 bg-background border border-border text-text-muted text-xs font-mono rounded-sm">
                {t}
              </span>
            ))}
          </div>
        </div>

        <!-- Links -->
        <div class="border-t border-border pt-5 flex flex-wrap gap-3">
          {project.links.huggingface && (
            <a
              href={project.links.huggingface}
              target="_blank"
              rel="noopener noreferrer"
              class="modal-link-btn"
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm-3.5-9c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm7 0c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-3.5 5c2.33 0 4.31-1.46 5.11-3.5H7.89C8.69 14.54 10.67 16 12 16z"/>
              </svg>
              Live Demo
            </a>
          )}
          {project.links.github && (
            <a
              href={project.links.github}
              target="_blank"
              rel="noopener noreferrer"
              class="modal-link-btn"
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.341-3.369-1.341-.454-1.154-1.11-1.462-1.11-1.462-.908-.62.069-.607.069-.607 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.087.636-1.337-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836a9.59 9.59 0 0 1 2.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.934.359.309.678.919.678 1.852 0 1.337-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.138 20.161 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
              </svg>
              GitHub
            </a>
          )}
          {project.links.colab && (
            <a
              href={project.links.colab}
              target="_blank"
              rel="noopener noreferrer"
              class="modal-link-btn"
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M4.54 9.46 2.19 7.1a6.93 6.93 0 0 0 0 9.79l2.35-2.35a3.59 3.59 0 0 1 0-5.08z" opacity=".8"/>
                <path d="m19.46 9.46-2.35 2.35a3.59 3.59 0 0 1 0 5.08l2.35 2.35a6.93 6.93 0 0 0 0-9.79z" opacity=".6"/>
                <path d="M14.54 7.1A6.86 6.86 0 0 0 12 6.5a6.86 6.86 0 0 0-2.54.5L7.1 4.65A10.33 10.33 0 0 1 12 3.5c1.77 0 3.43.44 4.9 1.15z" opacity=".4"/>
                <path d="m16.9 19.35-2.36-2.35a3.55 3.55 0 0 1-5.08 0L7.1 19.35A6.93 6.93 0 0 0 12 21a6.93 6.93 0 0 0 4.9-1.65z"/>
              </svg>
              Colab Notebook
            </a>
          )}
          {project.links.apiDocs && (
            <a
              href={project.links.apiDocs}
              target="_blank"
              rel="noopener noreferrer"
              class="modal-link-btn"
            >
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14,2 14,8 20,8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
              </svg>
              API Docs
            </a>
          )}
        </div>

      </div>
    </dialog>
  );
})}

<script>
  // Filter tabs
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('[data-category]');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;

      filterBtns.forEach((b) => {
        b.classList.remove('border-accent', 'text-accent', 'active-filter');
        b.classList.add('border-border', 'text-text-muted');
        b.setAttribute('aria-pressed', 'false');
      });

      btn.classList.add('border-accent', 'text-accent', 'active-filter');
      btn.classList.remove('border-border', 'text-text-muted');
      btn.setAttribute('aria-pressed', 'true');

      cards.forEach((card) => {
        const show = filter === 'all' || card.dataset.category === filter;
        card.style.display = show ? '' : 'none';
      });
    });
  });

  // Project card → open modal
  document.querySelectorAll<HTMLElement>('[data-modal-target]').forEach((card) => {
    const openModal = (e: Event) => {
      if ((e.target as Element).closest('a')) return;
      const modal = document.getElementById(card.dataset.modalTarget!) as HTMLDialogElement | null;
      modal?.showModal();
    };
    card.addEventListener('click', openModal);
    card.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openModal(e); }
    });
  });

  // Blog project card → navigate to case study page
  document.querySelectorAll<HTMLElement>('[data-blog-url]').forEach((card) => {
    const navigate = (e: Event) => {
      if ((e.target as Element).closest('a')) return;
      window.location.href = card.dataset.blogUrl!;
    };
    card.addEventListener('click', navigate);
    card.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); navigate(e); }
    });
  });

  // Close on backdrop click
  document.querySelectorAll<HTMLDialogElement>('.project-modal').forEach((modal) => {
    modal.addEventListener('click', (e) => {
      if (e.target === modal) modal.close();
    });
  });

  // Close button
  document.querySelectorAll<HTMLButtonElement>('.modal-close').forEach((btn) => {
    btn.addEventListener('click', () => {
      (btn.closest('dialog') as HTMLDialogElement | null)?.close();
    });
  });
</script>

<style>
  /* Project modal */
  .project-modal {
    background: #0F0F1A;
    border: 1px solid #1E1E2E;
    border-radius: 12px;
    padding: 0;
    max-width: min(680px, calc(100vw - 2rem));
    max-height: calc(100dvh - 3rem);
    overflow-y: auto;
    color: #F0F0F5;
    outline: none;
  }

  .project-modal::backdrop {
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .project-modal[open] {
    animation: modalIn 0.2s ease-out;
  }

  @keyframes modalIn {
    from { opacity: 0; transform: scale(0.96) translateY(8px); }
    to   { opacity: 1; transform: scale(1)    translateY(0);   }
  }

  .modal-inner {
    padding: 1.75rem;
  }

  .modal-link-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.5rem 1rem;
    background: #0A0A0F;
    border: 1px solid #1E1E2E;
    border-radius: 6px;
    color: #9898A8;
    font-family: "JetBrains Mono", monospace;
    font-size: 0.75rem;
    text-decoration: none;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }

  .modal-link-btn:hover {
    color: #00D9FF;
    border-color: rgba(0, 217, 255, 0.45);
    background: rgba(0, 217, 255, 0.05);
  }
</style>
